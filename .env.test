# ainything Test Environment
# Loaded by Vite when running: pnpm test, pnpm test:unit
# Uses local PostgreSQL + Redis for deterministic, fast, offline tests.
#
# Prerequisites:
#   pnpm infra:up
#   pnpm db:reset

PUBLIC_APP_URL=http://localhost:5173

# Database — local PostgreSQL via Podman/Docker
# Use 127.0.0.1 on Windows/WSL2 (localhost resolves to ::1 IPv6)
DATABASE_URL=postgresql://ainything_app:ainything_app@127.0.0.1:5432/ainything
DIRECT_URL=postgresql://ainything:ainything@127.0.0.1:5432/ainything

# Redis — local instance via Podman/Docker
REDIS_URL=redis://127.0.0.1:6379

# Session
SESSION_SECRET=test-session-secret-not-real

# Testing
RUN_DB_TESTS=true

# Auth — mock for tests
AUTH_PROVIDER=mock

# Providers — all mocked in tests
LLM_PROVIDER=mock
OCR_PROVIDER=mock
WHATSAPP_PROVIDER=mock
STORAGE_PROVIDER=mock
AI_DAILY_CAP=500
EMBEDDING_ENABLED=false
