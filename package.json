{
	"name": "lingua",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"packageManager": "pnpm@10.0.0",
	"engines": {
		"node": ">=22.0.0",
		"pnpm": ">=10.0.0"
	},
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . --ignore-unknown && eslint .",
		"format": "prettier --write . --ignore-unknown",
		"infra:up": "node scripts/infra.mjs up -d",
		"infra:down": "node scripts/infra.mjs down",
		"infra:logs": "node scripts/infra.mjs logs -f",
		"infra:ps": "node scripts/infra.mjs ps",
		"infra:pull": "node scripts/infra.mjs pull",
		"infra:reset": "node scripts/infra.mjs down -v && node scripts/infra.mjs up -d",
		"infra:doctor": "node scripts/infra.mjs doctor",
		"infra:shell:db": "node scripts/infra.mjs exec postgres psql -U lingua -d lingua",
		"infra:shell:redis": "node scripts/infra.mjs exec redis redis-cli",
		"db:migrate": "node scripts/db.mjs migrate",
		"db:seed": "node scripts/db.mjs seed",
		"db:reset": "node scripts/db.mjs reset",
		"test:unit": "vitest",
		"test": "pnpm run test:unit -- --run && pnpm run test:e2e",
		"test:e2e": "playwright test"
	},
	"dependencies": {
		"@ai-sdk/anthropic": "^3.0.84",
		"@ai-sdk/openai": "^3.0.71",
		"@ai-sdk/openai-compatible": "^2.0.50",
		"@lucide/svelte": "^1.18.0",
		"ai": "^6.0.206",
		"pg": "^8.21.0",
		"redis": "^6.0.0",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@playwright/test": "^1.60.0",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/vite": "^4.3.0",
		"@types/node": "^24",
		"@types/pg": "^8.20.0",
		"eslint": "^10.4.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.19.0",
		"globals": "^17.6.0",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^4.1.0",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"tailwindcss": "^4.3.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.60.1",
		"vite": "^8.0.16",
		"vitest": "^4.1.8"
	}
}
