{
	"name": "lingua",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"packageManager": "pnpm@10.0.0",
	"engines": {
		"node": ">=22.0.0",
		"pnpm": ">=10.0.0"
	},
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . --ignore-unknown && eslint .",
		"format": "prettier --write . --ignore-unknown",
		"infra:up": "node scripts/infra.mjs up -d",
		"infra:down": "node scripts/infra.mjs down",
		"infra:logs": "node scripts/infra.mjs logs -f",
		"infra:ps": "node scripts/infra.mjs ps",
		"infra:pull": "node scripts/infra.mjs pull",
		"infra:reset": "node scripts/infra.mjs down -v && node scripts/infra.mjs up -d",
		"infra:doctor": "node scripts/infra.mjs doctor",
		"infra:shell:db": "node scripts/infra.mjs exec postgres psql -U lingua -d lingua",
		"infra:shell:redis": "node scripts/infra.mjs exec redis redis-cli",
		"db:migrate": "node scripts/db.mjs migrate",
		"db:seed": "node scripts/db.mjs seed",
		"db:reset": "node scripts/db.mjs reset",
		"test:unit": "vitest",
		"test": "pnpm run test:unit -- --run && pnpm run test:e2e",
		"test:e2e": "playwright test",
		"bundle-check": "node scripts/check-bundle-size.mjs",
		"audit:deps": "node scripts/dependency-audit.mjs",
		"audit:a11y": "node scripts/accessibility-check.mjs",
		"perf": "node scripts/performance-check.mjs"
	},
	"dependencies": {
		"@ai-sdk/anthropic": "^3.0.84",
		"@ai-sdk/openai": "^3.0.71",
		"@ai-sdk/openai-compatible": "^2.0.50",
		"@lucide/svelte": "^1.18.0",
		"@sentry/sveltekit": "^10.59.0",
		"@supabase/ssr": "^0.12.0",
		"@supabase/supabase-js": "^2.108.2",
		"ai": "^6.0.206",
		"bits-ui": "2.18.1",
		"bullmq": "^5.79.1",
		"clsx": "^2.1.1",
		"mode-watcher": "^1.1.0",
		"nodemailer": "6.9.13",
		"pg": "^8.21.0",
		"qrcode": "^1.5.4",
		"redis": "^6.0.0",
		"svelte-sonner": "^1.1.1",
		"sveltekit-superforms": "^2.30.1",
		"tailwind-merge": "^3.6.0",
		"tailwind-variants": "^3.2.2",
		"tw-animate-css": "^1.4.0",
		"web-vitals": "4.2.4",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@axe-core/cli": "^4.10.0",
		"@eslint/js": "^10.0.1",
		"@playwright/test": "^1.60.0",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/vite": "^4.3.0",
		"@types/node": "^24",
		"@types/nodemailer": "6.4.14",
		"@types/pg": "^8.20.0",
		"@types/qrcode": "^1.5.6",
		"eslint": "^10.4.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.19.0",
		"globals": "^17.6.0",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^4.1.0",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"tailwindcss": "^4.3.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.60.1",
		"vite": "^8.0.16",
		"vitest": "^4.1.8"
	}
}
