# ainything Production Environment
# Template for self-hosted deployments (Docker Compose on VPS).
# Copy to .env.production.local and fill real values. DO NOT commit real secrets.
# For actual server deployment, set these in /opt/ainything/.env directly.

PUBLIC_APP_URL=https://ainything.online

# ---------------------------------------------------------------------------
# Auth — self-hosted Auth.js with credentials (bcrypt + PostgreSQL)
# ---------------------------------------------------------------------------
AUTH_PROVIDER=credentials

# Session signing — generate with: openssl rand -base64 32
SESSION_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND

# ---------------------------------------------------------------------------
# Database (PostgreSQL) — Docker service names, NOT 127.0.0.1
# DATABASE_URL: app connection (user: ainything_app, RLS-enforced role)
# DIRECT_URL: migration connection (user: ainything, superuser for schema changes)
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://ainything_app:CHANGE_ME@postgres:5432/ainything
DIRECT_URL=postgresql://ainything:CHANGE_ME@postgres:5432/ainything

# Redis — Docker service name
REDIS_URL=redis://redis:6379

# Storage — 'local' for VPS file uploads, 'mock' to disable
STORAGE_PROVIDER=local
STORAGE_LOCAL_PATH=/app/uploads

# ---------------------------------------------------------------------------
# LLM — set to a real provider when keys are configured
# ---------------------------------------------------------------------------
LLM_PROVIDER=mock
AI_DAILY_CAP=500

# Embedding / RAG
EMBEDDING_ENABLED=false

# ---------------------------------------------------------------------------
# External providers (all mocked until configured)
# ---------------------------------------------------------------------------
OCR_PROVIDER=mock
WHATSAPP_PROVIDER=mock

# Testing — disabled in production
RUN_DB_TESTS=false

# ---------------------------------------------------------------------------
# Optional (add when needed):
#   SMTP_HOST / SMTP_PORT / SMTP_USER / SMTP_PASS / SMTP_FROM  — email
#   ANTHROPIC_API_KEY or OPENAI_API_KEY                         — AI chat
#   STORAGE_PROVIDER=r2 + R2_* vars                            — Cloudflare R2
#   PUBLIC_SENTRY_DSN / SENTRY_AUTH_TOKEN                       — Sentry
# ---------------------------------------------------------------------------
