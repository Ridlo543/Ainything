# Lingua Production Environment
# Loaded by Vite when running: pnpm build, pnpm preview, NODE_ENV=production
# Copy to .env.production.local and fill real values. DO NOT commit real secrets.

PUBLIC_APP_URL=https://lingua.example.com

# Database (Supabase Postgres or managed Postgres)
DATABASE_URL=postgresql://lingua_app:CHANGE_ME@127.0.0.1:5432/lingua
DIRECT_URL=postgresql://lingua:CHANGE_ME@127.0.0.1:5432/lingua

# Redis (managed instance)
REDIS_URL=redis://127.0.0.1:6379

# Session signing — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('base64'))"
SESSION_SECRET=CHANGE_ME_GENERATE_WITH_CRYPTO_RANDOMBYTES

USE_MOCK_BACKEND=false

# ---------------------------------------------------------------------------
# Auth — production MUST use Supabase
# ---------------------------------------------------------------------------
AUTH_PROVIDER=supabase

PUBLIC_SUPABASE_URL=https://yljtcppbdwvjyziqyymv.supabase.co
PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_fBuQD5XVIEWkMS89FpNxrg_J5eopbYm
SUPABASE_SERVICE_ROLE_KEY=CHANGE_ME_SUPABASE_SERVICE_ROLE_KEY

# ---------------------------------------------------------------------------
# LLM — production MUST use a real provider
# ---------------------------------------------------------------------------
LLM_PROVIDER=tokenrouter
LLM_MODEL=MiniMax-M3
TOKENROUTER_API_KEY=CHANGE_ME_TOKENROUTER_API_KEY
TOKENROUTER_BASE_URL=https://api.tokenrouter.com/v1

# Direct provider keys (alternative to TokenRouter)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

AI_DAILY_CAP=500

# ---------------------------------------------------------------------------
# Embedding / RAG
# ---------------------------------------------------------------------------
EMBEDDING_ENABLED=false
LLM_EMBEDDING_MODEL=text-embedding-3-small

# ---------------------------------------------------------------------------
# External providers
# ---------------------------------------------------------------------------
OCR_PROVIDER=mock
WHATSAPP_PROVIDER=mock
STORAGE_PROVIDER=mock

# ---------------------------------------------------------------------------
# Testing — disabled in production
# ---------------------------------------------------------------------------
RUN_DB_TESTS=false
