PUBLIC_APP_URL=http://localhost:5173

# App runtime connection. This role is created by migrations and is subject to RLS.
DATABASE_URL=postgresql://lingua_app:lingua_app@localhost:5432/lingua

# Migration/seed connection. Keep this server-only and never expose it to the browser.
DIRECT_URL=postgresql://lingua:lingua@localhost:5432/lingua
REDIS_URL=redis://localhost:6379

SESSION_SECRET=replace-with-a-long-random-string
USE_MOCK_BACKEND=false

# Auth provider. 'mock' uses the demo HttpOnly cookie (local dev only).
# Set to 'supabase' in staging/production once Supabase Auth is configured.
AUTH_PROVIDER=mock

# LLM provider. 'mock' uses a placeholder that tells guests to ask staff.
# Phase 7 will add: openai, anthropic, gemini
LLM_PROVIDER=mock

# Daily AI-call cap per restaurant (tune after pilot based on LLM cost data).
AI_DAILY_CAP=500

# Optional: run DB/RLS unit tests after infra, migration, and seed are ready.
# RUN_DB_TESTS=true

# Optional future migration path
# PUBLIC_SUPABASE_URL=
# PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_JWT_SECRET=
