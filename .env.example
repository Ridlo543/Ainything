PUBLIC_APP_URL=http://localhost:5173

# App runtime connection. This role is created by migrations and is subject to RLS.
DATABASE_URL=postgresql://lingua_app:lingua_app@localhost:5432/lingua

# Migration/seed connection. Keep this server-only and never expose it to the browser.
DIRECT_URL=postgresql://lingua:lingua@localhost:5432/lingua
REDIS_URL=redis://localhost:6379

SESSION_SECRET=replace-with-a-long-random-string
USE_MOCK_BACKEND=false

# ---------------------------------------------------------------------------
# Auth provider
# 'mock'     — HttpOnly demo cookie (local dev only)
# 'supabase' — Supabase Auth via SSR cookies (staging / production)
# ---------------------------------------------------------------------------
AUTH_PROVIDER=mock

# ---------------------------------------------------------------------------
# LLM provider
# 'mock'        — Placeholder that tells guests to ask staff. No API key needed.
# 'tokenrouter' — TokenRouter OpenAI-compatible proxy (supports many models).
# 'openai'      — Direct OpenAI API.
# 'anthropic'   — Direct Anthropic API.
# ---------------------------------------------------------------------------
LLM_PROVIDER=mock

# Model to use. Defaults per provider:
#   tokenrouter → MiniMax-M3 (free tier for testing)
#   openai      → gpt-4o-mini
#   anthropic   → claude-haiku-4-5
# Override with any model the provider supports.
# LLM_MODEL=MiniMax-M3

# TokenRouter — OpenAI-compatible proxy key (get from tokenrouter.com)
# TOKENROUTER_API_KEY=sk-xxx
# TOKENROUTER_BASE_URL=https://api.tokenrouter.com/v1

# Direct provider keys (only needed when LLM_PROVIDER=openai or anthropic)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# Daily AI-call cap per restaurant. When exceeded, chat returns a "ask staff" response.
# Tune after pilot based on observed volume and LLM cost data.
AI_DAILY_CAP=500

# ---------------------------------------------------------------------------
# Embedding / RAG
# When true, the retrieval service uses pgvector semantic search to augment
# structured filtering. Requires an LLM provider that supports embeddings
# (e.g. OpenAI, TokenRouter). Falls back to structured-only when disabled.
# ---------------------------------------------------------------------------
EMBEDDING_ENABLED=false
LLM_EMBEDDING_MODEL=text-embedding-3-small

# ---------------------------------------------------------------------------
# Optional: run DB/RLS integration tests (requires infra up + db:migrate + db:seed)
# ---------------------------------------------------------------------------
# RUN_DB_TESTS=true

# ---------------------------------------------------------------------------
# Optional: run live LLM integration tests (hits real TokenRouter/MiniMax API)
# Requires LLM_PROVIDER=tokenrouter and TOKENROUTER_API_KEY to be set above.
# Will consume API quota. Only enable when you want to verify the live provider.
# ---------------------------------------------------------------------------
# RUN_LLM_TESTS=true

# ---------------------------------------------------------------------------
# Optional future: managed Supabase backend
# ---------------------------------------------------------------------------
# PUBLIC_SUPABASE_URL=
# PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_JWT_SECRET=
