# Lingua Environment Variables
# Copy this file to .env for development

# Application
NODE_ENV=development
PUBLIC_APP_URL=http://localhost:5173

# Backend
USE_MOCK_BACKEND=true

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:password@localhost:5432/lingua
DIRECT_URL=postgresql://postgres:password@localhost:5432/lingua?sslmode=disable

# Cache (Redis)
REDIS_URL=redis://localhost:6379

# Auth
AUTH_PROVIDER=mock

# LLM Provider
LLM_PROVIDER=mock
LLM_MODEL=

# API Keys (for production)
# TOKENROUTER_API_KEY=your-tokenrouter-api-key
# OPENAI_API_KEY=your-openai-api-key
# ANTHROPIC_API_KEY=your-anthropic-api-key

# Rate Limiting
AI_DAILY_CAP=500

# Feature Flags
EMBEDDING_ENABLED=false

# OCR
OCR_PROVIDER=mock

# WhatsApp
WHATSAPP_PROVIDER=mock

# Storage
STORAGE_PROVIDER=mock
