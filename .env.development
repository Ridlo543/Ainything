# Lingua Development Environment
# Loaded by Vite when running: pnpm dev, pnpm test:unit
# Safe defaults — no real secrets, all providers mocked.

PUBLIC_APP_URL=http://localhost:5173

# Database (local Postgres, created by pnpm db:migrate)
# Use 127.0.0.1 on Windows/WSL2 — localhost resolves to ::1 (IPv6)
DATABASE_URL=postgresql://lingua_app:lingua_app@127.0.0.1:5432/lingua
DIRECT_URL=postgresql://lingua:lingua@127.0.0.1:5432/lingua

# Redis (local instance for rate limiting and pub/sub)
REDIS_URL=redis://127.0.0.1:6379

# Session signing (random string, not a real secret in dev)
SESSION_SECRET=dev-session-secret-do-not-use-in-production-change-me

USE_MOCK_BACKEND=false

# ---------------------------------------------------------------------------
# Auth
# ---------------------------------------------------------------------------
# 'mock'     — HttpOnly demo cookie, no Supabase needed (default for dev)
# 'supabase' — Supabase Auth SSR cookies (requires PUBLIC_SUPABASE_*)
# ---------------------------------------------------------------------------
AUTH_PROVIDER=mock
# AUTH_PROVIDER=supabase

# ---------------------------------------------------------------------------
# LLM
# ---------------------------------------------------------------------------
# 'mock' — Returns "ask staff" placeholder. No API key, no network calls.
#          Safe for unit tests and local UI dev.
# ---------------------------------------------------------------------------
LLM_PROVIDER=mock
AI_DAILY_CAP=500

# Embedding / RAG (disabled in dev to avoid network calls)
EMBEDDING_ENABLED=false
LLM_EMBEDDING_MODEL=text-embedding-3-small

# ---------------------------------------------------------------------------
# External providers (all mocked in development)
# ---------------------------------------------------------------------------
OCR_PROVIDER=mock
WHATSAPP_PROVIDER=mock
STORAGE_PROVIDER=mock

# ---------------------------------------------------------------------------
# Supabase (only needed when AUTH_PROVIDER=supabase)
# ---------------------------------------------------------------------------
PUBLIC_SUPABASE_URL=https://yljtcppbdwvjyziqyymv.supabase.co
PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_fBuQD5XVIEWkMS89FpNxrg_J5eopbYm

# Still needed for server-side auth (SupabaseAuthProvider):
# SUPABASE_SERVICE_ROLE_KEY=eyJ...  (Settings → API → service_role key)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here  (Settings → API → service_role)

# DATABASE_URL must point to the Supabase pooler for server-side queries:
# DATABASE_URL=postgresql://postgres.yljtcppbdwvjyziqyymv:[YOUR-PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres

# ---------------------------------------------------------------------------
# Testing
# ---------------------------------------------------------------------------
# Tests use .env.test by default (local PostgreSQL + RUN_DB_TESTS=true).
# This file is for dev server only — pnpm test does not read this file.
# See .env.test for the test environment configuration.
